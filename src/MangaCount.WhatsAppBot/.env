# MangaCount WhatsApp Bot Configuration
# Copy this file to .env and customize the values

# ===========================================
# API Configuration
# ===========================================

# Base URL of the MangaCount .NET API
API_BASE_URL=http://localhost:5000/api

# API connection timeout in milliseconds
API_TIMEOUT=10000

# ===========================================
# Bot Configuration
# ===========================================

# WhatsApp session name (used for storing authentication)
SESSION_NAME=manga-bot-session

# Maximum message length (WhatsApp limit is 4096)
MAX_MESSAGE_LENGTH=4096

# ===========================================
# Logging Configuration
# ===========================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file path (relative to bot directory)
LOG_FILE=./logs/combined.log

# Error log file path
ERROR_LOG_FILE=./logs/error.log

# ===========================================
# Admin Configuration
# ===========================================

# Admin phone numbers (with country code, comma-separated)
# These users will receive notifications when bot starts/errors occur
# Example: ADMIN_NUMBERS=+1234567890,+0987654321
ADMIN_NUMBERS=

# ===========================================
# Security Configuration
# ===========================================

# OPTIONAL: Bot authentication token (if implementing auth)
# BOT_TOKEN=your-secret-token

# OPTIONAL: Allowed phone numbers (comma-separated, empty = allow all)
# ALLOWED_NUMBERS=+1234567890,+0987654321

# ===========================================
# Advanced Configuration
# ===========================================

# Puppeteer options for WhatsApp Web
PUPPETEER_HEADLESS=true

# Enable/disable group message handling (default: false)
ENABLE_GROUP_MESSAGES=false

# Enable/disable status broadcast handling (default: false)  
ENABLE_STATUS_MESSAGES=false

# Default profile to set for new users (optional)
DEFAULT_PROFILE=

# Enable detailed API request logging (default: false)
DEBUG_API_REQUESTS=false

# Message rate limiting (messages per minute, 0 = no limit)
RATE_LIMIT=0

# ===========================================
# Development Configuration
# ===========================================

# Environment mode: development, production
NODE_ENV=production

# Enable development features and extra logging
DEVELOPMENT_MODE=false

# ===========================================
# Customization
# ===========================================

# Bot response language (currently only Spanish supported)
BOT_LANGUAGE=es

# Time zone for timestamps (default: system timezone)
TIMEZONE=

# Custom welcome message (optional, will use default if empty)
CUSTOM_WELCOME_MESSAGE=

# ===========================================
# Example Configuration
# ===========================================
# 
# # Basic configuration for most users:
# API_BASE_URL=http://localhost:5000/api
# SESSION_NAME=my-manga-bot
# LOG_LEVEL=info
# ADMIN_NUMBERS=+1234567890
# 
# # Development configuration:
# LOG_LEVEL=debug
# DEVELOPMENT_MODE=true
# DEBUG_API_REQUESTS=true
# NODE_ENV=development
#